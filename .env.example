# Anthropic API key — used by topgun task add/start and other inference commands.
# Set this directly, or use TOPGUN_AUTH_HELPER instead (see below).
ANTHROPIC_API_KEY=

# Path to the auth helper binary that returns a bearer token via: <helper> auth token
# Alternative to ANTHROPIC_API_KEY for setups where the claude CLI is available.
# Example: TOPGUN_AUTH_HELPER=claude
TOPGUN_AUTH_HELPER=

# Anthropic API base URL (e.g. a corporate proxy)
ANTHROPIC_BASE_URL=
