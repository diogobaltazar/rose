# Anthropic API key — required for topgun task add and fuzzy task matching.
# Uses a TOPGUN_ prefix to avoid inheriting unrelated ANTHROPIC_* vars from
# the host shell environment (e.g. from other projects).
TOPGUN_ANTHROPIC_API_KEY=

# Anthropic API base URL — set only if using a corporate proxy.
TOPGUN_ANTHROPIC_BASE_URL=

# Optional custom header sent with every inference request (e.g. required by some proxies).
# Leave blank to omit the header entirely.
TOPGUN_PROXY_TOOL_HEADER=
TOPGUN_PROXY_TOOL_VALUE=

# tgun.dev webapp — Auth0 authentication (see docs/auth0-setup.md)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_AUDIENCE=

# tgun.dev backend server IP (Hetzner, see docs/hetzner-setup.md)
TGUNDEV_BACKEND_IP=
