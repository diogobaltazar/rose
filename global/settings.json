{
  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:8080",
    "ANTHROPIC_AUTH_TOKEN": "dummy-gateway-token",
    "ANTHROPIC_CUSTOM_HEADERS": "x-portkey-metadata: {\"_user\":\"diogo.pereira-marques@roche.com\",\"ona_user_id\":\"019d0332-cb44-724b-ad3f-525da52a87d4\",\"tool\":\"claude\"}",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(~/.claude/hooks/log-subagent-events.sh*)",
      "Bash(~/.claude/hooks/log-message-events.sh*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "HOOK_EVENT=PostToolUse:SendMessage ~/.claude/hooks/log-message-events.sh",
            "type": "command"
          }
        ],
        "matcher": "SendMessage"
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "HOOK_EVENT=SubagentStart ~/.claude/hooks/log-subagent-events.sh",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "HOOK_EVENT=SubagentStop ~/.claude/hooks/log-subagent-events.sh",
            "type": "command"
          }
        ]
      }
    ]
  }
}
